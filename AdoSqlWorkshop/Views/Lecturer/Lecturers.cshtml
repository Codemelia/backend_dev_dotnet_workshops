@using System.Security.Policy
@model IEnumerable<AdoSqlWorkshop.Models.Lecturer>

@{
    ViewData["Title"] = "Lecturer List";
}

<h1>Course List</h1>

<div>
    <hr />
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Username</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model)
            {
                <tr>
                    <td>@l.Id</td>
                    <td>@l.FirstName</td>
                    <td>@l.LastName</td>
                    <td>@l.Username</td>
                    <td>
                        <a href="@Url.Action(
                            "Index", "Course", 
                            new {lectId = l.Id})">View</a>
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>
